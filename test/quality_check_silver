-- Data Standardisation & consistence

select distinct 
	cntry as old_cntry,
	case when trim(cntry) = 'DE' THEN 'Germany'
		 when trim(cntry) in ('US', 'USA') then 'United States'
		 when trim(cntry) = '' or cntry is null then 'n/a'
		 else trim(cntry)
	end as cntry
from silver.erp_loc_a101
order by cntry

